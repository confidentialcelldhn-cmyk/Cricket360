{
  "expo": {
    "name": "Cricket360",
    "slug": "cricket360",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1628"
    },

    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.confidentialcell.cricket360"
    },

    "android": {
      "package": "com.confidentialcell.cricket360",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0A1628"
      }
    },

    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/icon.png"
    },

    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },

    "extra": {
      "eas": {
        "projectId": "e75e7a7f-80fd-4091-8be4-25cdc24bd8eb"
      }
    },

    "owner": "divisional-sports-association-cricket360"
  }
}
